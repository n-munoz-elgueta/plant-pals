FROM python:3.12-slim

WORKDIR /app

# Install dependencies first for better layer caching.
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Application code.
COPY app ./app

# The database lives in managed Postgres — set PLANTS_DATABASE_URL (and
# PLANTS_SECRET_KEY) as environment variables on the hosting platform.

EXPOSE 8000

# Hosting platforms inject $PORT; fall back to 8000 for local `docker run`.
CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"]
